<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm mt-4">
      <div class="card-header bg-white">
        <h3 class="mb-0 fw-bold">Edit Book</h3>
      </div>
      <div class="card-body">
        <form action="/edit/<%= book._id %>" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label fw-semibold">Book Title</label>
            <input type="text" class="form-control" id="title" name="title" value="<%= book.title %>" required>
          </div>
          <div class="mb-3">
            <label for="author" class="form-label fw-semibold">Author Name</label>
            <input type="text" class="form-control" id="author" name="author" value="<%= book.author %>" required>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="category" class="form-label fw-semibold">Category</label>
              <select class="form-select" id="category" name="category" required>
                <% const categories = ['Fiction', 'Non-Fiction', 'Finance', 'Self-Help', 'Science', 'Technology', 'History', 'Biography', 'Education']; %>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>" <%= book.category === cat ? 'selected' : '' %>><%= cat %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label for="price" class="form-label fw-semibold">Price (Rs.)</label>
              <input type="number" class="form-control" id="price" name="price" value="<%= book.price %>" required>
            </div>
          </div>
          <div class="mb-3">
            <label for="quantity" class="form-label fw-semibold">Quantity</label>
            <input type="number" class="form-control" id="quantity" name="quantity" value="<%= book.quantity %>" required>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label fw-semibold">Description</label>
            <textarea class="form-control" id="description" name="description" rows="3"><%= book.description %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold d-block">Current Cover</label>
            <% if (book.image) { %>
              <img src="/uploads/<%= book.image %>" alt="Book Cover" class="img-thumbnail mb-2" style="height: 100px;">
            <% } else { %>
              <p class="text-muted small">No cover uploaded</p>
            <% } %>
            <input type="file" class="form-control" id="image" name="image" accept="image/*">
            <div class="form-text">Upload a new image to replace the current one.</div>
          </div>
          <div class="d-flex gap-2 justify-content-end">
            <a href="/" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary px-4">Update Book</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
