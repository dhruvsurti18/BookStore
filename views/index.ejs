<%- include('partials/header') %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h2 class="fw-bold mb-1">All Books</h2>
  </div>
  <a href="/add" class="btn btn-primary px-4" id="add-book-btn">Add New Book</a>
</div>

<% if (books.length === 0) { %>
  <h5 align="center">No Books Added Yet... </h5>
<% } else { %>
  <div class="row g-4">
    <% books.forEach(function(book) { %>
      <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card h-100 shadow-sm">

          <% if (book.image) { %>
            <img src="/uploads/<%= book.image %>" class="card-img-top" alt="<%= book.title %>" style="height: 200px; object-fit: cover;" />
          <% } else { %>
            <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
              <span class="text-white">No Image</span>
            </div>
          <% } %>

          <div class="card-header bg-white border-bottom">
            <span class="badge bg-primary"><%= book.category %></span>
          </div>
          <div class="card-body">
            <h5 class="card-title fw-bold mb-1"><%= book.title %></h5>
            <p class="text-muted small mb-2"><%= book.author %></p>
            <% if (book.description) { %>
              <p class="card-text small text-secondary">
                <%= book.description.length > 80 ? book.description.substring(0, 80) + '...' : book.description %>
              </p>
            <% } %>
          </div>

          <div class="card-body pt-0 d-flex justify-content-between align-items-center border-top">
            <span class="fw-bold text-success fs-5">Rs. <%= book.price %></span>
            <span class="badge <%= book.quantity === 0 ? 'bg-danger' : 'bg-secondary' %>">Qty: <%= book.quantity %></span>
          </div>

          <div class="card-footer bg-white d-flex gap-2">
            <a href="/edit/<%= book._id %>" class="btn btn-warning btn-sm flex-fill" id="edit-<%= book._id %>">Edit</a>
            <form action="/delete/<%= book._id %>" method="POST" class="flex-fill" onsubmit="return confirm('Are you sure you want to delete this book?')">
              <button type="submit" class="btn btn-danger btn-sm w-100" id="delete-<%= book._id %>">Delete</button>
            </form>
          </div>

        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
